---
import DrinkCard from "@/components/DrinkCard.astro";
import config from "@/config/config.json";
import Base from "@/layouts/Base.astro";
import { getSinglePage } from "@/lib/contentParser.astro";
import { getTaxonomy } from "@/lib/taxonomyParser.astro";
import taxonomyFilter from "@/lib/utils/taxonomyFilter";
import PageHeader from "@/components/PageHeader.astro";

export async function getStaticPaths() {
  const bottles = await getTaxonomy(
    config.settings.drink_folder,
    "bottles"
  );

  return bottles.map((bottle) => {
    return {
      params: { bottle },
    };
  });
}

const { bottle } = Astro.params;
const posts = await getSinglePage(config.settings.drink_folder);
const filterByBottles = taxonomyFilter(posts, "bottles", bottle!);
---

<Base title={bottle}>
  <PageHeader title={bottle} />
  <div class="section-sm pb-0">
    <div class="container">
      <div class="row">
        {
          filterByBottles.map((post) => (
            <div class="mb-14 md:col-6 lg:col-4">
              <DrinkCard data={post} />
            </div>
          ))
        }
      </div>
    </div>
  </div>
</Base>
